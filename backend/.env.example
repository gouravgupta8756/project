# ============================================================
# PixelLift Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server port (default: 3001)
PORT=3001

# Allowed frontend origin (for CORS)
# In production, set this to your actual frontend URL
FRONTEND_URL=http://localhost:5500

# ── Background Removal API ──────────────────────────────────
# Option A: remove.bg (https://www.remove.bg/api)
#   Free tier: 50 API calls/month
REMOVE_BG_API_KEY=your_remove_bg_api_key_here

# Option B: ClipDrop (https://clipdrop.co/apis)
#   Alternative background removal service
# CLIPDROP_API_KEY=your_clipdrop_api_key_here

# ── Image Enhancement ───────────────────────────────────────
# We use the 'sharp' npm library (FREE, no API key needed!)
# It runs locally and handles: sharpening, brightness, clarity
# For AI upscaling, you can add:
# DEEPAI_API_KEY=your_deepai_key  (deepai.org - free tier available)

# ── Watermark ───────────────────────────────────────────────
# Set to 'true' to add watermark on free tier output
ADD_WATERMARK=true

# ── Rate Limiting ───────────────────────────────────────────
# Max API requests per IP per 15 minutes (server-side protection)
RATE_LIMIT_MAX=30
